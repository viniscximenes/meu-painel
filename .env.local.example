# Supabase - obter em https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
# service_role key — usada apenas no script de criação de usuários (NUNCA expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=id_da_sua_planilha
# Credenciais da Service Account (JSON em uma linha, com \n nos saltos de linha)
GOOGLE_SERVICE_ACCOUNT_EMAIL=sua-conta@projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE\n-----END PRIVATE KEY-----\n"
